@using Company.G02.DAL.Models
@model IEnumerable<Department>
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}
<h1>All Department</h1>
<br />
<br />
<a asp-action="Create" asp-controller="Department" class="btn btn-primary">Crete Department</a>

<br />
<br />

@if (!Model.Any())
{
    <p class="alert-danger">No Departments :(</p>
}
else
{
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Code</th>
                <th>Name</th>
                <th>DateOfCreation</th>
                <th>Detailes</th>
                <th>Update</th>
                <th>Delete</th>
            </tr>

        </thead>
        <tbody>
            @foreach (var item in Model)
            {

                <tr>
                    <td>
                        @item.Code
                    </td>
                    <td>
                        @item.Name
                    </td>
                    <td>
                        @item.CreateAt
                    </td>
                    <td>
                        <a asp-action="Detailes" class="btn btn-warning" asp-action="Detailes" asp-route-Id="@item.Id">Detailes</a>
                    </td>
                    <td>
                        <a asp-action="Edit" class="btn btn-success" asp-action="Edit" asp-route-Id="@item.Id">Update</a>
                    </td>
                    <td>
                        <a asp-action="Delete" class="btn btn-danger" asp-route-Id="@item.Id">Delete</a>
                    </td>
            </tr>
            }

    </tbody>
</table>

}

    

