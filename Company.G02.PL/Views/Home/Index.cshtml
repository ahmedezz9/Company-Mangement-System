@{
    ViewData["Title"] = "Dashboard";
}

<style>
    .hero-section {
        background: linear-gradient(135deg, #0f2a4a 0%, #1a3f6f 50%, #0d3460 100%);
    }

    .stat-icon {
        font-size: 28px;
        opacity: 0.15;
    }

    .action-btn:hover {
        border-color: #3b82f6 !important;
        box-shadow: 0 2px 8px rgba(59,130,246,0.1);
    }

    .av-1 {
        background: #dbeafe;
        color: #1d4ed8;
    }

    .av-2 {
        background: #dcfce7;
        color: #15803d;
    }

    .av-3 {
        background: #fef3c7;
        color: #b45309;
    }

    .av-4 {
        background: #ede9fe;
        color: #7c3aed;
    }
</style>

<!-- Hero -->
<div class="hero-section p-5 rounded-3 mb-4 position-relative overflow-hidden">
    <span class="badge rounded-pill mb-3 d-inline-block"
          style="background:rgba(255,255,255,0.12); color:#93c5fd;">
        Company Management System
    </span>
    <h1 class="fw-semibold text-white mb-2">
        Welcome back, <span class="text-primary">Admin</span> 👋
    </h1>
    <p class="mb-4" style="color:rgba(255,255,255,0.6); max-width:460px;">
        Manage your workforce and departments efficiently. Everything you need in one place.
    </p>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-controller="Employee" asp-action="Create"
           class="btn btn-primary">+ Add Employee</a>
        <a asp-controller="Department" asp-action="Index"
           class="btn btn-outline-light">View Departments</a>
    </div>
</div>

<!-- Stats -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm border-start border-primary border-4 p-3 position-relative">
            <div class="position-absolute top-0 end-0 p-3 stat-icon">👥</div>
            <div class="text-uppercase text-muted" style="font-size:11px; letter-spacing:0.5px;">Total Employees</div>
            <div class="fs-2 fw-semibold text-dark lh-1 my-1">@ViewBag.EmployeeCount</div>
            <div class="text-muted small">All records</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm border-start border-success border-4 p-3 position-relative">
            <div class="position-absolute top-0 end-0 p-3 stat-icon">🏛</div>
            <div class="text-uppercase text-muted" style="font-size:11px; letter-spacing:0.5px;">Departments</div>
            <div class="fs-2 fw-semibold text-dark lh-1 my-1">@ViewBag.DepartmentCount</div>
            <div class="text-muted small">All active</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm border-start border-warning border-4 p-3 position-relative">
            <div class="position-absolute top-0 end-0 p-3 stat-icon">✅</div>
            <div class="text-uppercase text-muted" style="font-size:11px; letter-spacing:0.5px;">Active</div>
            <div class="fs-2 fw-semibold text-dark lh-1 my-1">@ViewBag.EmployeeCount</div>
            <div class="text-muted small">All staff</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm border-start border-4 p-3 position-relative"
             style="border-color:#a855f7 !important;">
            <div class="position-absolute top-0 end-0 p-3 stat-icon">🆕</div>
            <div class="text-uppercase text-muted" style="font-size:11px; letter-spacing:0.5px;">Recent Added</div>
            <div class="fs-2 fw-semibold text-dark lh-1 my-1">4</div>
            <div class="text-muted small">Last entries</div>
        </div>
    </div>
</div>

<!-- Bottom -->
<div class="row g-3">
    <!-- Recent Employees -->
    <div class="col-md-6">
        <div class="card border-0 shadow-sm overflow-hidden">
            <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
                <span class="fw-semibold text-dark">Recent Employees</span>
                <a asp-controller="Employee" asp-action="Index"
                   class="text-primary text-decoration-none small">View all →</a>
            </div>
            <div class="card-body p-0">
                @{
                    var colors = new[] { "av-1", "av-2", "av-3", "av-4" };
                    int i = 0;
                }
                @foreach (var emp in ViewBag.RecentEmployees)
                {
                    var initials = emp.Name.Length >= 2
                    ? emp.Name.Substring(0, 2).ToUpper()
                    : emp.Name.ToUpper();
                    <div class="d-flex align-items-center gap-3 px-4 py-3 border-bottom">
                        <div class="avatar rounded-circle d-flex align-items-center justify-content-center fw-semibold flex-shrink-0 @colors[i % 4]"
                             style="width:38px; height:38px; font-size:13px;">
                            @initials
                        </div>
                        <div>
                            <div class="fw-semibold text-dark" style="font-size:13px;">@emp.Name</div>
                            <div class="text-muted" style="font-size:12px;">@emp.Department?.Name</div>
                        </div>
                    </div>
                    i++;
                }
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3">
                <span class="fw-semibold text-dark">Quick Actions</span>
            </div>
            <div class="card-body">
                <div class="row g-2">
                    <div class="col-6">
                        <a asp-controller="Employee" asp-action="Create"
                           class="action-btn d-flex flex-column align-items-start gap-1 p-3 rounded-3 border bg-light text-decoration-none text-dark h-100 transition">
                            <span style="font-size:22px;">👤</span>
                            <span class="fw-semibold" style="font-size:13px;">Add Employee</span>
                            <span class="text-muted" style="font-size:11px;">Create new record</span>
                        </a>
                    </div>
                    <div class="col-6">
                        <a asp-controller="Department" asp-action="Create"
                           class="action-btn d-flex flex-column align-items-start gap-1 p-3 rounded-3 border bg-light text-decoration-none text-dark h-100">
                            <span style="font-size:22px;">🏛</span>
                            <span class="fw-semibold" style="font-size:13px;">Add Department</span>
                            <span class="text-muted" style="font-size:11px;">New department</span>
                        </a>
                    </div>
                    <div class="col-6">
                        <a asp-controller="Employee" asp-action="Index"
                           class="action-btn d-flex flex-column align-items-start gap-1 p-3 rounded-3 border bg-light text-decoration-none text-dark h-100">
                            <span style="font-size:22px;">📋</span>
                            <span class="fw-semibold" style="font-size:13px;">All Employees</span>
                            <span class="text-muted" style="font-size:11px;">Browse records</span>
                        </a>
                    </div>
                    <div class="col-6">
                        <a asp-controller="Department" asp-action="Index"
                           class="action-btn d-flex flex-column align-items-start gap-1 p-3 rounded-3 border bg-light text-decoration-none text-dark h-100">
                            <span style="font-size:22px;">🏢</span>
                            <span class="fw-semibold" style="font-size:13px;">All Departments</span>
                            <span class="text-muted" style="font-size:11px;">Browse all</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>