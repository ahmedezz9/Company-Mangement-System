<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Company.G02.PL</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Company.G02.PL.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark mb-4 shadow-sm" style="background:#0f2a4a;">
            <div class="container-fluid">

                <!-- Brand -->
                <a class="navbar-brand fw-semibold d-flex align-items-center gap-2"
                   asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="bg-primary rounded-2 d-flex align-items-center justify-content-center"
                          style="width:32px; height:32px; font-size:16px;">🏢</span>
                    Company<span class="text-primary">.G02</span>
                </a>

                <!-- Toggler -->
                <button class="navbar-toggler border-0" type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbarContent"
                        aria-controls="navbarContent"
                        aria-expanded="false"
                        aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarContent">

                    <!-- Left Links -->
                    <ul class="navbar-nav me-auto mb-2 mb-sm-0">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white-50 px-3 rounded-2"
                                   asp-area="" asp-controller="Home" asp-action="Index">
                                    Home
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white-50 px-3 rounded-2"
                                   asp-area="" asp-controller="Department" asp-action="Index">
                                    Departments
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white-50 px-3 rounded-2"
                                   asp-area="" asp-controller="Employee" asp-action="Index">
                                    Employees
                                </a>
                            </li>
                        }
                    </ul>

                    <!-- Right Side -->
                    <ul class="navbar-nav ms-auto mb-2 mb-sm-0 align-items-center gap-2">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <span class="navbar-text text-white-50 small">
                                    👤 @User.Identity.Name
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-outline-danger btn-sm"
                                   asp-area="" asp-controller="Account" asp-action="SignOut">
                                    Sign Out
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-outline-light btn-sm"
                                   asp-area="" asp-controller="Account" asp-action="SignIn">
                                    Sign In
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-primary btn-sm"
                                   asp-area="" asp-controller="Account" asp-action="SignUp">
                                    Sign Up
                                </a>
                            </li>
                        }
                    </ul>

                </div>
            </div>
        </nav>
    </header>
    
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Company.G02.PL - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/lib/jquery-validation/dist/additional-methods.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
