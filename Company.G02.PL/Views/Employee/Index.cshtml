@using Company.G02.DAL.Models
@model IEnumerable<Employee>
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}


<h1>All Employees</h1>
<br />
<br />
<a asp-action="Create" class="btn btn-primary">Create Employee</a>
<br />
<br />

@if (Model.Any())
{
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Name</th>
                <th>Age</th>
                <th>Email</th>
                <th>Address</th>
                <th>Phone</th>
                <th>Salary</th>
                <th>IsActive</th>
                <th>IsDeleted</th>
                <th>Detailes</th>
                <th>Update</th>
                <th>Delete</th>
                
            </tr>

        </thead>
        <tbody>
            @foreach (var item in Model)
            {

                <tr>
                    <td>
                        @item.Name
                    </td>
                    <td>
                        @item.Age
                    </td>
                    <td>
                        @item.Email
                    </td>
                    <td>
                        @item.Address
                    </td>
                    <td>
                        @item.Phone
                    </td>
                    <td>
                        @item.Salary</td>
                        <td>
                        @item.IsActive
                    </td>
                    <td>
                        @item.IsDeleted
                    </td>
                    <td>
                        @(item.Department?.Name ?? "No Department")
                    </td>

                    <td>
                        <a asp-action="Detailes" class="btn btn-warning"  asp-route-Id="@item.Id">Detailes</a>
                    </td>
                    <td>
                        <a asp-action="Edit" class="btn btn-success" asp-action="Edit" asp-route-Id="@item.Id">Update</a>
                    </td>
                    <td>
                        <a asp-action="Delete" class="btn btn-danger" asp-route-Id="@item.Id">Delete</a>
                    </td>
                </tr>
            }

        </tbody>
    </table>
}
else
{
    <p class="alert-danger">No Employees Yet :(</p>
}